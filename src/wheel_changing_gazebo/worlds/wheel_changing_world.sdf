      <!-- Attaches center_lug_nut to the installed new wheel after socket seats it -->
      <plugin filename="gz-sim8-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>wheel_link</parent_link>
        <child_model>center_lug_nut</child_model>
        <child_model_link>nut_link</child_model_link>
        <child_link>nut_link</child_link>

        <detach_topic>/lug_nut_wheel_joint/detach</detach_topic>
        <attach_topic>/lug_nut_wheel_joint/attach</attach_topic>
        <output_topic>/lug_nut_wheel_joint/state</output_topic>
        <suppress_child_warning>true</suppress_child_warning>
      </plugin>
      <!-- END_LUG_NUT_WHEEL_DETACHABLE_PLUGIN -->

    </model>


  </world>
</sdf>
