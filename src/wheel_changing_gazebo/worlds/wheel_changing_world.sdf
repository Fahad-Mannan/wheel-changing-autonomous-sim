    <model name="center_lug_nut">
      <static>false</static>
      <pose>-0.82750 0.17000 0.95000 0.00000 1.57080 3.14159</pose>
      <link name="nut_link">
        <gravity>false</gravity>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <iyy>0.0001</iyy>
            <izz>0.0001</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>

        <visual name="nut_visual">
          <geometry>
            <cylinder>
              <radius>0.018</radius>
              <length>0.025</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.65 0.05 1</ambient>
            <diffuse>0.95 0.65 0.05 1</diffuse>
            <specular>0.30 0.20 0.05 1</specular>
