<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="wheel_changing_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>6 6</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>6 6</size></plane></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Changing station: old wheel mounted on stand in front of the manipulator. -->
    
    <!-- Changing station: old wheel mounted on stand in front of the manipulator. -->
    
    <!-- Changing station: old wheel mounted on stand in front of the manipulator. -->
    <model name="changing_station_stand">
      <static>true</static>
      <self_collide>true</self_collide>
      <pose>-0.99000 0.17000 0.45000 0.00000 0.00000 0.00000</pose>

      <link name="post">
        <visual name="post_visual">
          <geometry>
            <box>
              <size>0.04 0.04 1.00</size>
            </box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
        <collision name="post_collision">
          <geometry>
            <box>
              <size>0.04 0.04 1.00</size>
            </box>
          </geometry>
        </collision>
      </link>

      <link name="hub">
        <pose>0 0 0.50 0 1.5708 0</pose>

        <visual name="hub_visual">
          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.12</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>

        <!-- Tiny collision only, so the visual hub does not physically block wheel removal -->
        <collision name="hub_collision">
          <geometry>
            <cylinder>
              <radius>0.002</radius>
              <length>0.005</length>
            </cylinder>
          </geometry>
        </collision>
      </link>

      <!-- BEGIN_STAND_WHEEL_DETACHABLE_PLUGIN -->
      <!-- Keeps old_wheel fixed to the stand until the gripper is ready to pull it -->
      <plugin filename="gz-sim8-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>hub</parent_link>
        <child_model>old_wheel</child_model>

        <!-- Gazebo Sim versions differ in this tag name; include both safely. -->
        <child_model_link>wheel_link</child_model_link>
        <child_link>wheel_link</child_link>

        <detach_topic>/wheel_stand_joint/detach</detach_topic>
        <attach_topic>/wheel_stand_joint/attach</attach_topic>
        <output_topic>/wheel_stand_joint/state</output_topic>
        <suppress_child_warning>true</suppress_child_warning>
      </plugin>
      <!-- END_STAND_WHEEL_DETACHABLE_PLUGIN -->

    </model>



    
    
    
    
    <model name="old_wheel">
      <static>false</static>
      <pose>-0.88000 0.17000 0.95000 0.00000 1.57080 3.14159</pose>
      <link name="wheel_link">
        <gravity>true</gravity>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.01</ixx>
            <iyy>0.01</iyy>
            <izz>0.01</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
