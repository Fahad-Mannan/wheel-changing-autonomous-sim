            <cylinder>
              <radius>0.018</radius>
              <length>0.025</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>80.0</mu>
                <mu2>80.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1000000.0</kp>
                <kd>100.0</kd>
                <max_vel>0.01</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
      </link>
    </model>



<!-- Dumping zone: 120 degrees counterclockwise from changing station. -->
    <model name="dumping_zone">
      <static>true</static>
      <pose>0.45000 -0.85000 0.01500 0.00000 0.00000 -3.14159</pose>
      <link name="zone_link">
        <visual name="zone_visual">
          <geometry><box><size>0.75 0.75 0.03</size></box></geometry>
          <material><ambient>0.8 0.15 0.15 1</ambient><diffuse>0.8 0.15 0.15 1</diffuse></material>
        </visual>
        <collision name="zone_collision"><geometry><box><size>0.75 0.75 0.03</size></box></geometry></collision>
      </link>
    </model>

    <!-- Supply zone: 120 degrees clockwise from changing station. -->
    <model name="supply_zone">
      <static>true</static>
      <pose>0.45000 0.85000 0.01500 0.00000 0.00000 -3.14159</pose>
      <link name="zone_link">
        <visual name="zone_visual">
          <geometry><box><size>0.75 0.75 0.03</size></box></geometry>
          <material><ambient>0.15 0.45 0.8 1</ambient><diffuse>0.15 0.45 0.8 1</diffuse></material>
        </visual>
        <collision name="zone_collision"><geometry><box><size>0.75 0.75 0.03</size></box></geometry></collision>
      </link>
    
      <!-- BEGIN_NEW_WHEEL_DETACHABLE_PLUGIN -->
      <!-- Keeps new_wheel_supply fixed to the blue zone until gripper is ready -->
      <plugin filename="gz-sim8-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>zone_link</parent_link>
        <child_model>new_wheel_supply</child_model>
        <child_model_link>wheel_link</child_model_link>
        <child_link>wheel_link</child_link>

        <detach_topic>/new_wheel_joint/detach</detach_topic>
        <attach_topic>/new_wheel_joint/attach</attach_topic>
        <output_topic>/new_wheel_joint/state</output_topic>
        <suppress_child_warning>true</suppress_child_warning>
      </plugin>
      <!-- END_NEW_WHEEL_DETACHABLE_PLUGIN -->

    </model>

    
