<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!--
    Custom coaxial dual end-effector for the wheel-changing project.
    - Outer gripper: four larger fingers around wheel rim.
    - Inner socket: small central rotating/socket-like tool for the single center lug nut.
    - Camera: mounted above/behind the coaxial tools at the common neck.

    Version 1 is mainly visual/kinematic. Later we will add real gripper joints,
    contact constraints, and attach/detach plugins.
  -->

  <xacro:macro name="dual_coaxial_end_effector" params="parent prefix:=ee">

    <link name="${prefix}_neck_link">
      <inertial>
        <mass value="0.7"/>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
        <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
        <geometry><cylinder radius="0.055" length="0.08"/></geometry>
        <material name="ee_dark_gray"><color rgba="0.12 0.12 0.12 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
        <geometry><cylinder radius="0.055" length="0.08"/></geometry>
      </collision>
    </link>

    <joint name="${prefix}_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}_neck_link"/>
      <!-- Tool extends along +Z of tool0 for this first version. If your UR10e tool frame points differently, adjust this rpy. -->
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>
    <!-- ========================================================== -->
    <!-- Larger 3-jaw outer wheel gripper                           -->
    <!-- 3 blue hands slide radially outward/inward to grab wheel.  -->
    <!-- ========================================================== -->

    <link name="${prefix}_outer_ring_link">
      <inertial>
        <mass value="0.9"/>
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
      </inertial>

      <!-- central blue back plate -->
      <visual name="outer_gripper_back_plate">
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.018" radius="0.18"/>
        </geometry>
        <material name="ee_blue">
          <color rgba="0.05 0.22 0.75 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}_outer_ring_fixed_joint" type="fixed">
      <parent link="${prefix}_neck_link"/>
      <child link="${prefix}_outer_ring_link"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </joint>

    <!-- BEGIN_OUTER_HAND_COMMON_SLIDE -->
    <link name="${prefix}_outer_hand_slide_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${prefix}_outer_hand_slide_joint" type="prismatic">
      <parent link="${prefix}_outer_ring_link"/>
      <child link="${prefix}_outer_hand_slide_link"/>
      <origin xyz="0 0 -0.120" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="0.220" effort="300" velocity="0.20"/>
      <dynamics damping="1.0" friction="0.1"/>
    </joint>
    <!-- END_OUTER_HAND_COMMON_SLIDE -->


    <!-- Outer wheel hand 1 -->
    <link name="${prefix}_outer_hand1_link">
      <inertial>
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <mass value="0.18"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
      <visual name="outer_hand1_visual">
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
        <material name="outer_hand_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="outer_hand1_collision">
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_outer_hand1_joint" type="prismatic">
      <parent link="${prefix}_outer_hand_slide_link"/>
      <child link="${prefix}_outer_hand1_link"/>
      <origin xyz="-0.1342 -0.0775 0.0750" rpy="0 0 -2.6180"/>
      <axis xyz="-1 0 0"/>
      <limit lower="0.0" upper="0.060" effort="300" velocity="0.05"/>
      <dynamics damping="3.0" friction="1.0"/>
    </joint>
    <!-- Outer wheel hand 2 -->
    <link name="${prefix}_outer_hand2_link">
      <inertial>
        <origin xyz="0.0125 0 0.0900" rpy="0 0 0"/>
        <mass value="0.18"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
      <visual name="outer_hand2_visual">
        <origin xyz="0.0125 0 0.0900" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
        <material name="outer_hand_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="outer_hand2_collision">
        <origin xyz="0.0125 0 0.0900" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_outer_hand2_joint" type="prismatic">
      <parent link="${prefix}_outer_hand_slide_link"/>
      <child link="${prefix}_outer_hand2_link"/>
      <origin xyz="0.0000 0.1500 0.0950" rpy="0 0 1.5708"/>
      <axis xyz="-1 0 0"/>
      <limit lower="0.0" upper="0.060" effort="300" velocity="0.05"/>
      <dynamics damping="3.0" friction="1.0"/>
    </joint>


    <!-- Outer wheel hand 3 -->
    <link name="${prefix}_outer_hand3_link">
      <inertial>
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <mass value="0.18"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
      <visual name="outer_hand3_visual">
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
        <material name="outer_hand_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="outer_hand3_collision">
        <origin xyz="0.0125 0 0.1150" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.030 0.280"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_outer_hand3_joint" type="prismatic">
      <parent link="${prefix}_outer_hand_slide_link"/>
      <child link="${prefix}_outer_hand3_link"/>
      <origin xyz="0.1342 -0.0775 0.0750" rpy="0 0 -0.5236"/>
      <axis xyz="-1 0 0"/>
      <limit lower="0.0" upper="0.060" effort="300" velocity="0.05"/>
      <dynamics damping="3.0" friction="1.0"/>
    </joint>

    <!-- ========================================================== -->
    <!-- Sliding inner socket mechanism                             -->
    <!-- Socket is shorter and starts behind the outer wheel hands. -->
    <!-- It slides forward to reach the lug nut.                    -->
    <!-- ========================================================== -->

    <link name="${prefix}_socket_slide_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${prefix}_socket_slide_joint" type="prismatic">
      <parent link="${prefix}_neck_link"/>
      <child link="${prefix}_socket_slide_link"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="0.160" effort="80" velocity="0.20"/>
      <dynamics damping="0.4" friction="0.05"/>
    </joint>

    <link name="${prefix}_inner_socket_link">
      <inertial>
        <mass value="0.25"/>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0007"/>
      </inertial>

      <!-- shortened orange socket -->
      <visual name="short_inner_socket_visual">
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.130" radius="0.035"/>
        </geometry>
        <material name="ee_orange">
          <color rgba="0.95 0.45 0.08 1"/>
        </material>
      </visual>
</link>

    <joint name="${prefix}_socket_spin_joint" type="continuous">
      <parent link="${prefix}_socket_slide_link"/>
      <child link="${prefix}_inner_socket_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- ========================================================== -->
    <!-- 3 small sliding fingers around the shortened socket mouth  -->
    <!-- These grip the center lug nut.                             -->
    <!-- ========================================================== -->

    <link name="${prefix}_finger1_link">
      <visual name="finger1_visual">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
        <material name="finger_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="finger1_collision">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="-0.015 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${prefix}_finger1_joint" type="prismatic">
      <parent link="${prefix}_inner_socket_link"/>
      <child link="${prefix}_finger1_link"/>
      <origin xyz="0.038 0.000 0.145" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="0.020" effort="30" velocity="0.05"/>
      <dynamics damping="2.0" friction="0.2"/>
    </joint>

    <link name="${prefix}_finger2_link">
      <visual name="finger2_visual">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
        <material name="finger_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="finger2_collision">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="-0.015 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${prefix}_finger2_joint" type="prismatic">
      <parent link="${prefix}_inner_socket_link"/>
      <child link="${prefix}_finger2_link"/>
      <origin xyz="-0.019 0.0329 0.145" rpy="0 0 2.0944"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="0.020" effort="30" velocity="0.05"/>
      <dynamics damping="2.0" friction="0.2"/>
    </joint>

    <link name="${prefix}_finger3_link">
      <visual name="finger3_visual">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
        <material name="finger_yellow">
          <color rgba="1.0 0.85 0.05 1.0"/>
        </material>
      </visual>
      <collision name="finger3_collision">
        <origin xyz="-0.015 0 0.003" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.008 0.014"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="-0.015 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${prefix}_finger3_joint" type="prismatic">
      <parent link="${prefix}_inner_socket_link"/>
      <child link="${prefix}_finger3_link"/>
      <origin xyz="-0.019 -0.0329 0.145" rpy="0 0 -2.0944"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="0.020" effort="30" velocity="0.05"/>
      <dynamics damping="2.0" friction="0.2"/>
    </joint>






 


    <link name="${prefix}_camera_link">
      <visual name="camera_body_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.08 0.05 0.04"/>
        </geometry>
        <material name="camera_black">
          <color rgba="0.02 0.02 0.02 1.0"/>
        </material>
      </visual>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
                 iyy="0.00002" iyz="0.0"
                 izz="0.00002"/>
      </inertial>
      <!-- BEGIN_CAMERA_SUPPORT_STICK -->
      <!-- Thin black stick from camera bottom center to arm/end-effector surface -->
      <visual name="camera_support_stick_visual">
        <origin xyz="0 0 -0.118" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.005" length="0.270"/>
        </geometry>
        <material name="camera_support_black">
          <color rgba="0.02 0.02 0.02 1.0"/>
        </material>
      </visual>
      <!-- END_CAMERA_SUPPORT_STICK -->

    </link>

    <joint name="${prefix}_camera_joint" type="fixed">
      <parent link="${prefix}_neck_link"/>
      <child link="${prefix}_camera_link"/>
      <!-- Camera placed on the neck, looking forward toward the tool center line. -->
      <origin xyz="0 -0.3 -0.13" rpy="1.5708 -1.5708 0"/>
    </joint>

    
    <link name="${prefix}_camera_optical_frame"/>

    <joint name="${prefix}_camera_optical_joint" type="fixed">
      <parent link="${prefix}_camera_link"/>
      <child link="${prefix}_camera_optical_frame"/>
      <!-- ROS optical frame: x right, y down, z forward -->
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>

    <gazebo reference="${prefix}_camera_link">
      <sensor name="ee_rgbd_camera" type="rgbd_camera">
        <topic>/ee_rgbd_camera</topic>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>10.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
    </gazebo>

  
    <!-- BEGIN_SOCKET_FINGER_HIGH_FRICTION -->
    <!-- High friction between socket fingers and lug nut -->
    <gazebo reference="${prefix}_finger1_link">
      <mu1>80.0</mu1>
      <mu2>80.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
    </gazebo>

    <gazebo reference="${prefix}_finger2_link">
      <mu1>80.0</mu1>
      <mu2>80.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
    </gazebo>

    <gazebo reference="${prefix}_finger3_link">
      <mu1>80.0</mu1>
      <mu2>80.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
    </gazebo>
    <!-- END_SOCKET_FINGER_HIGH_FRICTION -->

</xacro:macro>
</robot>
