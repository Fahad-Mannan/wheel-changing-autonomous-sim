    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.015 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="ee_finger1_joint" type="prismatic">
    <parent link="ee_inner_socket_link"/>
    <child link="ee_finger1_link"/>
    <origin rpy="0 0 0" xyz="0.038 0.000 0.145"/>
    <axis xyz="1 0 0"/>
    <limit effort="30" lower="0.0" upper="0.020" velocity="0.05"/>
    <dynamics damping="2.0" friction="0.2"/>
  </joint>
  <link name="ee_finger2_link">
    <visual name="finger2_visual">
      <origin rpy="0 0 0" xyz="-0.015 0 0.003"/>
      <geometry>
        <box size="0.030 0.008 0.014"/>
      </geometry>
      <material name="finger_yellow">
        <color rgba="1.0 0.85 0.05 1.0"/>
      </material>
    </visual>
    <collision name="finger2_collision">
      <origin rpy="0 0 0" xyz="-0.015 0 0.003"/>
      <geometry>
        <box size="0.030 0.008 0.014"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.015 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="ee_finger2_joint" type="prismatic">
    <parent link="ee_inner_socket_link"/>
    <child link="ee_finger2_link"/>
    <origin rpy="0 0 2.0944" xyz="-0.019 0.0329 0.145"/>
    <axis xyz="1 0 0"/>
    <limit effort="30" lower="0.0" upper="0.020" velocity="0.05"/>
    <dynamics damping="2.0" friction="0.2"/>
  </joint>
  <link name="ee_finger3_link">
    <visual name="finger3_visual">
      <origin rpy="0 0 0" xyz="-0.015 0 0.003"/>
      <geometry>
        <box size="0.030 0.008 0.014"/>
      </geometry>
      <material name="finger_yellow">
        <color rgba="1.0 0.85 0.05 1.0"/>
      </material>
    </visual>
    <collision name="finger3_collision">
      <origin rpy="0 0 0" xyz="-0.015 0 0.003"/>
      <geometry>
        <box size="0.030 0.008 0.014"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.015 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="ee_finger3_joint" type="prismatic">
    <parent link="ee_inner_socket_link"/>
    <child link="ee_finger3_link"/>
    <origin rpy="0 0 -2.0944" xyz="-0.019 -0.0329 0.145"/>
    <axis xyz="1 0 0"/>
    <limit effort="30" lower="0.0" upper="0.020" velocity="0.05"/>
    <dynamics damping="2.0" friction="0.2"/>
  </joint>
  <link name="ee_camera_link">
    <visual name="camera_body_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.08 0.05 0.04"/>
      </geometry>
      <material name="camera_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00002"/>
    </inertial>
    <!-- BEGIN_CAMERA_SUPPORT_STICK -->
    <!-- Thin black stick from camera bottom center to arm/end-effector surface -->
    <visual name="camera_support_stick_visual">
      <origin rpy="0 0 0" xyz="0 0 -0.118"/>
      <geometry>
        <cylinder length="0.270" radius="0.005"/>
      </geometry>
      <material name="camera_support_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <!-- END_CAMERA_SUPPORT_STICK -->
  </link>
  <joint name="ee_camera_joint" type="fixed">
    <parent link="ee_neck_link"/>
    <child link="ee_camera_link"/>
    <!-- Camera placed on the neck, looking forward toward the tool center line. -->
    <origin rpy="1.5708 -1.5708 0" xyz="0 -0.3 -0.13"/>
  </joint>
  <link name="ee_camera_optical_frame"/>
  <joint name="ee_camera_optical_joint" type="fixed">
    <parent link="ee_camera_link"/>
    <child link="ee_camera_optical_frame"/>
    <!-- ROS optical frame: x right, y down, z forward -->
    <origin rpy="-1.5708 0 -1.5708" xyz="0 0 0"/>
  </joint>
  <gazebo reference="ee_camera_link">
    <sensor name="ee_rgbd_camera" type="rgbd_camera">
      <topic>/ee_rgbd_camera</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  <!-- BEGIN_SOCKET_FINGER_HIGH_FRICTION -->
  <!-- High friction between socket fingers and lug nut -->
  <gazebo reference="ee_finger1_link">
    <mu1>80.0</mu1>
    <mu2>80.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="ee_finger2_link">
    <mu1>80.0</mu1>
    <mu2>80.0</mu2>
