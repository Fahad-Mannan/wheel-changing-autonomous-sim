    <axis xyz="0 0 1"/>
  </joint>
  <!-- ========================================================== -->
  <!-- 3 small sliding fingers around the shortened socket mouth  -->
  <!-- These grip the center lug nut.                             -->
  <!-- ========================================================== -->
  <link name="ee_finger1_link">
    <visual name="finger1_visual">
      <origin rpy="0 0 0" xyz="-0.015 0 0.003"/>
      <geometry>
