    <origin rpy="0 0 0" xyz="0 0 0.02"/>
  </joint>
  <!-- ========================================================== -->
  <!-- Larger 3-jaw outer wheel gripper                           -->
  <!-- 3 blue hands slide radially outward/inward to grab wheel.  -->
  <!-- ========================================================== -->
  <link name="ee_outer_ring_link">
    <inertial>
      <mass value="0.9"/>
      <origin rpy="0 0 0" xyz="0 0 0.08"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
